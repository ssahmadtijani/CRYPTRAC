# Environment
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cryptrac?schema=public

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Blockchain RPC
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Compliance
SAR_THRESHOLD=10000
CTR_THRESHOLD=10000
TRAVEL_RULE_THRESHOLD=1000

# Logging
LOG_LEVEL=info
