// Prisma Database Schema for CRYPTRAC
// National Crypto Transaction Monitoring & Tax Compliance System (NCTMTCS)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TransactionType {
  TRANSFER
  TRADE
  DEPOSIT
  WITHDRAWAL
  SWAP
  STAKING
  MINING
  AIRDROP
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ComplianceStatus {
  PENDING
  APPROVED
  FLAGGED
  REJECTED
  UNDER_REVIEW
}

enum ReportType {
  SAR
  CTR
  TRAVEL_RULE
  TAX_SUMMARY
}

enum UserRole {
  ADMIN
  COMPLIANCE_OFFICER
  ANALYST
  AUDITOR
  USER
}

enum TaxEventType {
  CAPITAL_GAIN_SHORT
  CAPITAL_GAIN_LONG
  INCOME
  MINING_INCOME
  STAKING_REWARD
  AIRDROP_INCOME
}

enum ExchangeTransactionType {
  BUY
  SELL
  DEPOSIT
  WITHDRAWAL
  SWAP
  STAKING_REWARD
  MINING_REWARD
  AIRDROP
}

enum AssessmentPeriod {
  Q1
  Q2
  Q3
  Q4
  ANNUAL
}

enum AssessmentStatus {
  DRAFT
  CALCULATED
  REVIEWED
  FILED
  PAID
}


// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

enum CaseStatus {
  OPEN
  INVESTIGATING
  ESCALATED
  PENDING_REVIEW
  RESOLVED
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CaseCategory {
  SUSPICIOUS_TRANSACTION
  SANCTIONS_HIT
  HIGH_RISK_WALLET
  TRAVEL_RULE_VIOLATION
  STRUCTURING
  UNUSUAL_PATTERN
  MANUAL_REFERRAL
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(USER)
  firstName    String?
  lastName     String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  transactions         Transaction[]
  wallets              Wallet[]
  taxEvents            TaxEvent[]
  exchangeConnections  ExchangeConnection[]
  exchangeTransactions ExchangeTransaction[]
  taxableEvents        TaxableEvent[]
  taxAssessments       TaxAssessment[]
  costBasisLots        CostBasisLot[]
  reviewedReports      ComplianceReport[] @relation("ReviewedReports")
  assignedCases        Case[]             @relation("AssignedCases")
  createdCases         Case[]             @relation("CreatedCases")
  resolvedCases        Case[]             @relation("ResolvedCases")

  @@index([email])
}

model Transaction {
  id                 String           @id @default(uuid())
  userId             String
  type               TransactionType
  txHash             String?
  senderAddress      String
  receiverAddress    String
  asset              String
  amount             Float
  amountUSD          Float
  fee                Float            @default(0)
  feeUSD             Float            @default(0)
  blockNumber        Int?
  network            String
  riskLevel          RiskLevel        @default(LOW)
  riskScore          Float            @default(0)
  complianceStatus   ComplianceStatus @default(PENDING)
  metadata           Json?
  timestamp          DateTime
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user              User              @relation(fields: [userId], references: [id])
  complianceReports ComplianceReport[]

  @@index([userId])
  @@index([txHash])
  @@index([riskLevel])
  @@index([complianceStatus])
}

model Wallet {
  id               String    @id @default(uuid())
  address          String    @unique
  network          String
  label            String?
  riskScore        Float     @default(0)
  riskLevel        RiskLevel @default(LOW)
  isSanctioned     Boolean   @default(false)
  sanctionDetails  String?
  userId           String
  firstSeen        DateTime  @default(now())
  lastSeen         DateTime  @default(now())
  transactionCount Int       @default(0)
  totalVolumeUSD   Float     @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([address])
}

model ComplianceReport {
  id            String           @id @default(uuid())
  reportType    ReportType
  transactionId String
  status        ComplianceStatus @default(PENDING)
  narrative     String?
  findings      Json?
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  transaction Transaction      @relation(fields: [transactionId], references: [id])
  reviewedBy  User?            @relation("ReviewedReports", fields: [reviewedById], references: [id])

  @@index([transactionId])
  @@index([reportType])
  @@index([status])
}

model TaxEvent {
  id               String       @id @default(uuid())
  userId           String
  transactionId    String
  eventType        TaxEventType
  asset            String
  amount           Float
  costBasis        Float
  proceeds         Float
  gainLoss         Float
  holdingPeriodDays Int
  taxYear          Int
  taxableAmount    Float
  taxRate          Float
  taxOwed          Float
  createdAt        DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([taxYear])
}

model ExchangeConnection {
  id               String    @id @default(uuid())
  userId           String
  exchangeName     String
  status           String    @default("connected")
  lastSyncedAt     DateTime?
  transactionCount Int       @default(0)
  connectedAt      DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, exchangeName])
  @@index([userId])
}

model ExchangeTransaction {
  id             String                  @id @default(uuid())
  userId         String
  exchangeId     String
  exchangeName   String
  externalTxId   String
  type           ExchangeTransactionType
  asset          String
  amount         Float
  pricePerUnit   Float
  totalValueUSD  Float
  fee            Float                   @default(0)
  feeUSD         Float                   @default(0)
  counterAsset   String?
  counterAmount  Float?
  walletAddress  String?
  timestamp      DateTime
  createdAt      DateTime                @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([exchangeName])
  @@index([timestamp])
}

model TaxableEvent {
  id                String       @id @default(uuid())
  userId            String
  type              TaxEventType
  asset             String
  amount            Float
  proceedsUSD       Float
  costBasisUSD      Float
  gainLossUSD       Float
  holdingPeriodDays Int
  isLongTerm        Boolean      @default(false)
  exchange          String
  sourceTransaction String
  timestamp         DateTime
  taxRate           Float
  taxAmountUSD      Float
  taxAmountNGN      Float
  isFlagged         Boolean      @default(false)
  createdAt         DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([exchange])
  @@index([timestamp])
}

model TaxAssessment {
  id                    String           @id @default(uuid())
  userId                String
  taxYear               Int
  period                AssessmentPeriod
  totalTransactions     Int              @default(0)
  totalTaxableEvents    Int              @default(0)
  totalProceedsUSD      Float            @default(0)
  totalCostBasisUSD     Float            @default(0)
  netCapitalGainUSD     Float            @default(0)
  shortTermGainUSD      Float            @default(0)
  longTermGainUSD       Float            @default(0)
  stakingIncomeUSD      Float            @default(0)
  miningIncomeUSD       Float            @default(0)
  airdropIncomeUSD      Float            @default(0)
  totalIncomeUSD        Float            @default(0)
  capitalGainsTaxUSD    Float            @default(0)
  incomeTaxUSD          Float            @default(0)
  totalTaxLiabilityUSD  Float            @default(0)
  totalTaxLiabilityNGN  Float            @default(0)
  exchangeBreakdown     Json?
  walletBreakdown       Json?
  status                AssessmentStatus @default(DRAFT)
  reviewedBy            String?
  reviewedAt            DateTime?
  filedAt               DateTime?
  generatedAt           DateTime         @default(now())
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, taxYear, period])
  @@index([userId])
  @@index([taxYear])
  @@index([status])
}

model CostBasisLot {
  id          String   @id @default(uuid())
  userId      String
  asset       String
  amount      Float
  costPerUnit Float
  totalCost   Float
  acquiredAt  DateTime
  exchange    String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, asset])
}

model BlockSyncState {
  id          String    @id @default(uuid())
  network     String    @unique
  lastBlock   Int
  targetBlock Int?
  isRunning   Boolean   @default(false)
  lastError   String?
  updatedAt   DateTime  @updatedAt

  @@index([network])
}

model WatchedAddress {
  id        String   @id @default(uuid())
  address   String
  network   String
  label     String?
  addedBy   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([address, network])
  @@index([address])
  @@index([isActive])
}

model SanctionEntry {
  id          String   @id @default(uuid())
  address     String
  name        String?
  source      String
  listType    String
  details     String?
  addedAt     DateTime
  lastChecked DateTime @default(now())

  @@index([address])
  @@index([source])
}

model ExchangeReportSubmission {
  id               String    @id @default(uuid())
  exchangeName     String
  reportingPeriod  String
  periodStart      DateTime
  periodEnd        DateTime
  status           String    @default("PENDING")
  totalRecords     Int       @default(0)
  validRecords     Int       @default(0)
  errorRecords     Int       @default(0)
  validationErrors Json?
  submittedBy      String?
  processedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([exchangeName])
  @@index([status])
}

model Case {
  id              String         @id @default(uuid())
  caseNumber      String         @unique
  title           String
  description     String         @db.Text
  category        CaseCategory
  status          CaseStatus     @default(OPEN)
  priority        CasePriority   @default(MEDIUM)
  riskLevel       RiskLevel      @default(MEDIUM)

  assigneeId      String?
  assignee        User?          @relation("AssignedCases", fields: [assigneeId], references: [id])

  createdById     String
  createdBy       User           @relation("CreatedCases", fields: [createdById], references: [id])

  resolvedById    String?
  resolvedBy      User?          @relation("ResolvedCases", fields: [resolvedById], references: [id])
  resolvedAt      DateTime?
  resolution      String?        @db.Text

  escalatedTo     String?
  escalatedAt     DateTime?
  dueDate         DateTime?

  transactionIds  String[]
  walletAddresses String[]
  tags            String[]
  findings        Json?

  notes           CaseNote[]
  timeline        CaseTimeline[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([assigneeId])
  @@index([createdById])
  @@index([caseNumber])
  @@index([riskLevel])
  @@index([createdAt])
}

model CaseNote {
  id          String   @id @default(uuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id])
  authorId    String
  content     String   @db.Text
  noteType    String   @default("GENERAL")
  attachments String[]
  createdAt   DateTime @default(now())

  @@index([caseId])
  @@index([authorId])
}

model CaseTimeline {
  id            String   @id @default(uuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id])
  action        String
  performedById String
  previousValue String?
  newValue      String?
  metadata      Json?
  timestamp     DateTime @default(now())

  @@index([caseId])
  @@index([timestamp])
}
