{
  "name": "cryptrac",
  "version": "0.1.0",
  "description": "Crypto Transaction Reporting and Compliance System — National Crypto Transaction Monitoring & Tax Compliance System (NCTMTCS)",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --coverage",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "migrate": "prisma migrate dev",
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "crypto",
    "compliance",
    "FATF",
    "AML",
    "CFT",
    "travel-rule",
    "tax",
    "blockchain"
  ],
  "author": "ssahmadtijani",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.1",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "winston": "^3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.1",
    "prisma": "^5.20.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
